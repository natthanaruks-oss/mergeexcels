{
  "name": "mergeexcels",
  "version": "3.0.0",
  "private": true,
  "description": "Browser-based Excel and PDF merge, combine, and split toolkit for Cloudflare Workers Static Assets",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "vendor": "node scripts/copy-vendor.mjs",
    "dev": "npm run vendor && wrangler dev",
    "deploy": "npm run vendor && wrangler deploy",
    "test": "node tests/excel-ops.test.cjs && node tests/pdf-ops.test.cjs"
  },
  "dependencies": {
    "jszip": "3.10.1",
    "pdf-lib": "1.17.1",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "wrangler": "4.102.0"
  }
}
