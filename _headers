:root {
  color-scheme: light;
  --ink: #14213d;
  --muted: #637083;
  --line: #dce3ea;
  --surface: #ffffff;
  --canvas: #f4f7fa;
  --accent: #1f7a52;
  --accent-dark: #14563a;
  --accent-soft: #e7f4ed;
  --warning: #9a6500;
  --danger: #b42318;
  --shadow: 0 18px 55px rgba(20, 33, 61, 0.1);
  font-family: Inter, "Noto Sans Thai", "Segoe UI", Tahoma, sans-serif;
}

* { box-sizing: border-box; }
body {
  margin: 0;
  min-height: 100vh;
  color: var(--ink);
  background:
    radial-gradient(circle at 10% 5%, rgba(31, 122, 82, 0.09), transparent 32rem),
    var(--canvas);
}
button, input { font: inherit; }
button { cursor: pointer; }

.site-header {
  display: flex;
  align-items: center;
  gap: 14px;
  max-width: 1180px;
  margin: 0 auto;
  padding: 28px 24px 18px;
}
.brand-mark {
  display: grid;
  place-items: center;
  width: 48px;
  height: 48px;
  border-radius: 14px;
  background: var(--accent);
  color: white;
  font-size: 25px;
  font-weight: 800;
  box-shadow: 0 10px 25px rgba(31, 122, 82, 0.25);
}
.site-header h1 { margin: 0; font-size: 24px; letter-spacing: -0.03em; }
.site-header p { margin: 3px 0 0; color: var(--muted); }

.app-shell { max-width: 1180px; margin: 0 auto; padding: 10px 24px 48px; }
.mode-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
  margin-bottom: 18px;
}
.mode-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-height: 164px;
  padding: 20px;
  border: 1px solid var(--line);
  border-radius: 18px;
  background: rgba(255,255,255,0.78);
  color: var(--ink);
  text-align: left;
  transition: 160ms ease;
}
.mode-card:hover { transform: translateY(-2px); border-color: #b8c7d3; }
.mode-card.active {
  border-color: var(--accent);
  background: var(--accent-soft);
  box-shadow: 0 9px 30px rgba(31, 122, 82, 0.12);
}
.mode-number {
  position: absolute;
  top: 16px;
  right: 18px;
  color: #9aa6b2;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 0.08em;
}
.mode-card strong { margin: 4px 0 8px; font-size: 19px; }
.mode-card span:not(.mode-number) { color: #3f4c5d; line-height: 1.45; }
.mode-card small { margin-top: auto; padding-top: 12px; color: var(--muted); }

.workspace {
  padding: 28px;
  border: 1px solid var(--line);
  border-radius: 24px;
  background: var(--surface);
  box-shadow: var(--shadow);
}
.workspace-header {
  display: flex;
  justify-content: space-between;
  gap: 18px;
  align-items: flex-start;
  margin-bottom: 22px;
}
.workspace-header h2 { margin: 3px 0 6px; font-size: 25px; letter-spacing: -0.025em; }
.workspace-header p { margin: 0; color: var(--muted); }
.eyebrow { color: var(--accent) !important; font-size: 12px; font-weight: 800; letter-spacing: 0.12em; }
.text-button { border: 0; background: transparent; color: var(--accent-dark); font-weight: 700; padding: 7px; }

.drop-zone {
  display: grid;
  place-items: center;
  min-height: 210px;
  padding: 24px;
  border: 2px dashed #b8c7d3;
  border-radius: 20px;
  background: #f9fbfc;
  text-align: center;
  transition: 160ms ease;
}
.drop-zone:hover, .drop-zone.dragging { border-color: var(--accent); background: var(--accent-soft); }
.drop-zone input { position: absolute; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
.drop-zone strong { margin: 10px 0 5px; font-size: 17px; }
.drop-zone span:last-child { color: var(--muted); font-size: 14px; }
.upload-icon {
  display: grid;
  place-items: center;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: white;
  color: var(--accent);
  font-size: 28px;
  font-weight: 500;
  box-shadow: 0 7px 20px rgba(20, 33, 61, 0.08);
}

.file-summary {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1px;
  margin: 18px 0 12px;
  overflow: hidden;
  border: 1px solid var(--line);
  border-radius: 14px;
  background: var(--line);
}
.file-summary div { display: flex; align-items: baseline; gap: 7px; padding: 14px 18px; background: white; }
.file-summary strong { font-size: 20px; }
.file-summary span { color: var(--muted); font-size: 13px; }

.file-list { display: grid; gap: 8px; }
.file-item {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto auto;
  align-items: center;
  gap: 14px;
  padding: 12px 14px;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: #fff;
}
.file-item-name { min-width: 0; }
.file-item-name strong { display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 14px; }
.file-item-name small, .file-meta { color: var(--muted); font-size: 12px; }
.remove-file { width: 30px; height: 30px; border: 0; border-radius: 9px; background: #f3f5f7; color: #667085; }
.remove-file:hover { background: #fee4e2; color: var(--danger); }

.options-panel {
  margin-top: 18px;
  padding: 18px;
  border: 1px solid var(--line);
  border-radius: 16px;
  background: #fafcfd;
}
.options-panel h3 { margin: 0 0 12px; font-size: 15px; }
.check-row { display: flex; gap: 12px; padding: 10px 0; }
.check-row + .check-row { border-top: 1px solid var(--line); }
.check-row input { margin-top: 3px; accent-color: var(--accent); }
.check-row strong, .check-row small { display: block; }
.check-row small { margin-top: 3px; color: var(--muted); }
.hidden { display: none !important; }

.output-row { display: grid; grid-template-columns: 190px minmax(0, 1fr); align-items: center; gap: 14px; margin-top: 20px; }
.output-row label { font-weight: 700; }
.output-row input {
  width: 100%;
  padding: 12px 14px;
  border: 1px solid var(--line);
  border-radius: 11px;
  color: var(--ink);
  outline: none;
}
.output-row input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(31, 122, 82, 0.11); }

.status-box { display: flex; align-items: center; gap: 9px; margin-top: 18px; color: var(--muted); font-size: 13px; }
.status-dot { width: 9px; height: 9px; border-radius: 50%; background: #98a2b3; }
.status-box.success .status-dot { background: var(--accent); }
.status-box.error { color: var(--danger); }
.status-box.error .status-dot { background: var(--danger); }
.status-box.working .status-dot { background: #e6a700; animation: pulse 1s infinite alternate; }
.progress-track { height: 5px; margin-top: 9px; overflow: hidden; border-radius: 99px; background: #edf1f4; }
.progress-bar { width: 0%; height: 100%; background: var(--accent); transition: width 180ms ease; }
@keyframes pulse { to { opacity: 0.35; } }

.primary-button {
  width: 100%;
  margin-top: 18px;
  padding: 14px 20px;
  border: 0;
  border-radius: 13px;
  background: var(--accent);
  color: white;
  font-weight: 800;
  box-shadow: 0 9px 24px rgba(31, 122, 82, 0.22);
}
.primary-button:hover:not(:disabled) { background: var(--accent-dark); }
.primary-button:disabled { cursor: not-allowed; background: #aab4bd; box-shadow: none; }

.notes { margin-top: 22px; padding: 26px 4px; }
.notes h2 { margin: 0 0 14px; font-size: 18px; }
.note-grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 14px; }
.note-grid article { padding: 17px; border: 1px solid var(--line); border-radius: 14px; background: rgba(255,255,255,0.72); }
.note-grid p { margin: 6px 0 0; color: var(--muted); line-height: 1.55; }
.privacy-note { margin: 18px 0 5px; color: var(--accent-dark); font-weight: 700; }
.limitation-note { margin: 0; color: var(--muted); font-size: 13px; }
footer { padding: 24px; color: var(--muted); text-align: center; font-size: 12px; }

@media (max-width: 760px) {
  .mode-grid, .note-grid { grid-template-columns: 1fr; }
  .mode-card { min-height: 135px; }
  .workspace { padding: 20px; border-radius: 18px; }
  .workspace-header { display: block; }
  .text-button { margin-top: 8px; padding-left: 0; }
  .file-summary { grid-template-columns: 1fr; }
  .file-item { grid-template-columns: minmax(0, 1fr) auto; }
  .file-meta { grid-column: 1 / -1; }
  .output-row { grid-template-columns: 1fr; gap: 7px; }
}
